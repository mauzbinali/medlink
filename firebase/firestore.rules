rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isDoctor() {
      return userRole() == 'doctor';
    }

    match /users/{uid} {
      allow read, update: if isOwner(uid) || isAdmin();
      allow create: if signedIn() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if true;
      allow create, update: if isAdmin() || isDoctor();
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /prescriptions/{prescriptionId} {
      allow read: if signedIn();
      allow create, update: if isDoctor() || isAdmin();
      allow delete: if isAdmin();
    }

    match /medical_records/{recordId} {
      allow read, create, update: if signedIn();
      allow delete: if signedIn();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /health_tips/{tipId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn();
      allow create: if signedIn();
      allow delete: if isAdmin();
    }
  }
}
